{
  "name": "@atlas/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./dist/tokens/index.js"
    },
    "./web": {
      "types": "./src/web/index.ts",
      "import": "./dist/web/index.js"
    },
    "./native": {
      "types": "./src/native/index.ts",
      "import": "./dist/native/index.js"
    },
    "./tokens.css": "./src/tokens/tokens.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@atlas/types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": true },
    "react-native": { "optional": true }
  },
  "devDependencies": {
    "@atlas/config-tsconfig": "workspace:*",
    "@types/react": "^18.3.3",
    "@types/react-native": "^0.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.74.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.3"
  }
}
