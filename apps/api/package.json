{
  "name": "@atlas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "node test/e2e-smoke.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "clean": "rimraf dist .wrangler"
  },
  "dependencies": {
    "@atlas/domain": "workspace:*",
    "@atlas/types": "workspace:*",
    "drizzle-orm": "^0.32.0",
    "postgres": "^3.4.4",
    "hono": "^4.5.0",
    "jose": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@atlas/config-tsconfig": "workspace:*",
    "@cloudflare/workers-types": "^4.20240712.0",
    "drizzle-kit": "^0.23.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2",
    "wrangler": "^3.65.0"
  }
}
