{
  "name": "atlas-averbadora",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas Averbadora — plataforma digital de averbacao de credito consignado publico.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "mcp:build": "pnpm --filter @atlas/mcp-* run build",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.0.6",
    "typescript": "^5.5.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["@types/react", "react", "react-dom"]
    }
  }
}
