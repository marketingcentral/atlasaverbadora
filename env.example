# Atlas Averbadora — template de segredos locais
#
# Copie este arquivo para `env` (sem extensao) na raiz e preencha com valores reais.
# O arquivo `env` esta no `.gitignore` (linha 74) e NUNCA deve ser commitado.
# Ver regra 6 do `.claude/CLAUDE.md` para detalhes de uso/rotacao.

# Cloudflare — deploy do Worker (api) e Pages (web)
# Crie token em: https://dash.cloudflare.com/profile/api-tokens
# Permissoes: Account: Cloudflare Pages: Edit + Workers Scripts: Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# GitHub — PAT classico ou fine-grained com escopo `repo` no atlasaverbadora
# Crie em: https://github.com/settings/tokens
# Espelhar em `~/.git-credentials` para `git push` sem prompt:
#   https://USUARIO:TOKEN@github.com
GITHUB_TOKEN=

# TestSprite — geracao de testes E2E
# Crie em: https://app.testsprite.com (dashboard > API keys)
TESTSPRITE_API_KEY=

# Cloudflare R2 — bucket de assets/arquivos do projeto
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_S3_ENDPOINT=
